generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Empresa de transporte (São Bento, Ribe, etc)
model Empresa {
  id        Int      @id @default(autoincrement())
  nome      String   @unique
  slug      String   @unique  // ex: "saobento", "ribe"
  sourceUrl String?
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())

  rotas     Rota[]
}

// Rota entre duas cidades
model Rota {
  id           Int      @id @default(autoincrement())
  empresaId    Int
  origem       String
  destino      String
  linha        String?  // ex: "Ribeirão Preto X Brodowski"
  tarifaComum  Float?
  tarifaEstudante Float?
  ativo        Boolean  @default(true)
  atualizadoEm DateTime @default(now())
  criadoEm     DateTime @default(now())

  empresa   Empresa   @relation(fields: [empresaId], references: [id])
  horarios  Horario[]

  @@unique([empresaId, origem, destino])
}

// Horário individual de uma rota
model Horario {
  id          Int      @id @default(autoincrement())
  rotaId      Int
  horario     String   // ex: "05:00"
  diaDaSemana String   // "Segunda a Sexta" | "Sábado" | "Domingo e Feriados"
  sentido     String   // "ida" | "volta"
  tipo        String   @default("rodoviaria") // "rodoviaria" | "intermediario"
  observacao  String?
  ativo       Boolean  @default(true)
  criadoEm   DateTime @default(now())

  rota Rota @relation(fields: [rotaId], references: [id], onDelete: Cascade)

  @@unique([rotaId, horario, diaDaSemana, sentido])
}

// Log de cada raspagem executada
model LogRaspagem {
  id           Int      @id @default(autoincrement())
  origem       String
  destino      String
  empresaSlug  String
  status       String   // "sucesso" | "erro" | "vazio"
  totalHorarios Int     @default(0)
  erro         String?
  executadoEm  DateTime @default(now())
}
