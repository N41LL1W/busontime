generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id        Int      @id @default(autoincrement())
  nome      String   @unique
  slug      String   @unique
  sourceUrl String?
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())
  rotas     Rota[]
}

model Rota {
  id              Int       @id @default(autoincrement())
  empresaId       Int
  origem          String
  destino         String
  linha           String?
  tarifaComum     Float?
  tarifaEstudante Float?
  ativo           Boolean   @default(true)
  atualizadoEm    DateTime  @default(now())
  criadoEm        DateTime  @default(now())
  horarios        Horario[]
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, origem, destino])
}

model Horario {
  id          Int      @id @default(autoincrement())
  diaDaSemana String
  horario     String
  observacao  String?
  ativo       Boolean  @default(true)
  criadoEm    DateTime @default(now())
  rotaId      Int
  sentido     String
  tipo        String   @default("rodoviaria")
  rota        Rota     @relation(fields: [rotaId], references: [id], onDelete: Cascade)

  @@unique([rotaId, horario, diaDaSemana, sentido])
}

model LogRaspagem {
  id            Int      @id @default(autoincrement())
  origem        String
  destino       String
  empresaSlug   String
  status        String
  totalHorarios Int      @default(0)
  erro          String?
  executadoEm   DateTime @default(now())
}
